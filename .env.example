# App
APP_NAME=Gym Management
APP_PORT=3100
NODE_ENV=development
LOG_LEVEL=debug

# Database
DATABASE_DRIVER=postgres
DATABASE_FILE=.data/gym-management.sqlite
POSTGRES_HOST=localhost
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5434
POSTGRES_DB=gym_management
POSTGRES_SSL=false

# Frontend
FRONTEND_URL=http://localhost:5173

# JWT Auth
JWT_SECRET=change_this_jwt_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d
JWT_RESET_PASSWORD_SECRET=change_this_reset_secret
PASSWORD_RESET_TOKEN_EXPIRES_IN=15m
PASSWORD_RESET_PATH=/reset-password

# Optional local development flags
REDIS_ENABLED=true
MAIL_ENABLED=true
STORAGE_DRIVER=s3
LOCAL_STORAGE_PUBLIC_URL=http://localhost:3100/uploads

# Redis
REDIS_PASSWORD=password
REDIS_PORT=6380
REDIS_URL=redis://:password@localhost:6380

# Logging stack
OPENSEARCH_PORT=9201
DASHBOARDS_PORT=5602

# OpenSearch security
OPENSEARCH_ADMIN_USER=admin
OPENSEARCH_ADMIN_PASSWORD=complex_Password_123!

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=abcd@gmail.com
MAIL_PASS="abcd dsfs fdsf"
MAIL_FROM="Gym Management <noreply@example.com>"
MAIL_SECURE=false

# Default admin account
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin1234

# S3 Storage (SeaweedFS)
SEAWEEDFS_MASTER_PORT=9334
SEAWEEDFS_VOLUME_PORT=8081
SEAWEEDFS_FILER_PORT=8889
SEAWEEDFS_FILER_S3_PORT=8334
S3_ENDPOINT=http://localhost:8334
S3_PUBLIC_URL=http://localhost:8889/buckets/medias
S3_REGION=us-east-1
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin
S3_BUCKET=medias
S3_FORCE_PATH_STYLE=true
